{
  "name": "real-time-observability-platform",
  "version": "1.0.0",
  "description": "Production-grade observability stack: Node.js + Prometheus + Loki + Grafana + Docker",
  "main": "app/index.js",
  "scripts": {
    "start": "node app/index.js",
    "dev": "nodemon app/index.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint 'app/**/*.js' 'tests/**/*.js'",
    "lint:fix": "eslint 'app/**/*.js' 'tests/**/*.js' --fix",
    "format": "prettier --write 'app/**/*.js' 'tests/**/*.js'",
    "format:check": "prettier --check 'app/**/*.js' 'tests/**/*.js'",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:build": "docker compose build --no-cache"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageThreshold": {
      "global": {
        "lines": 70,
        "functions": 70,
        "branches": 60
      }
    },
    "coveragePathIgnorePatterns": ["/node_modules/"]
  },
  "keywords": ["observability", "prometheus", "grafana", "loki", "monitoring", "nodejs"],
  "author": "Aryan Vatsal",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "prom-client": "^15.1.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^19.2.2",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.3",
    "prettier": "^3.2.5",
    "supertest": "^6.3.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
